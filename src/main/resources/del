spring.application.name=javasocketchat

# HikariDataSource连接池配置
# 数据库连接配置
spring.datasource.url=jdbc:mysql://${DB_HOST:localhost}:${DB_PORT:3306}/${DB_NAME:javachat}?${DB_PARAMETERS:useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true}
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD:MySQL}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
# 连接池配置
spring.datasource.maximum-pool-size=20
spring.datasource.minimum-idle=5
spring.datasource.connection-timeout=30000
spring.datasource.idle-timeout=600000
spring.datasource.max-lifetime=1800000


# Redis
spring.redis.host=${REDIS_HOST:127.0.0.1}
spring.redis.port=${REDIS_PORT:6379}
# spring.redis.password
spring.redis.database=0
spring.redis.timeout=3000ms


# RabbitMQ
spring.rabbitmq.host=${MQ_HOST:localhost}
spring.rabbitmq.port=${MQ_HOST:5672}
spring.rabbitmq.username=${MQ_USERNAME:guest}
spring.rabbitmq.password=${MQ_PASSWORD:guest}
# 可选配置
# spring.rabbitmq.virtual-host=/
# spring.rabbitmq.connection-timeout=5000
# 开启消息确认
spring.rabbitmq.publisher-confirms=true
spring.rabbitmq.publisher-returns=true
spring.rabbitmq.listener.simple.acknowledge-mode=manual
spring.rabbitmq.listener.simple.prefetch=1